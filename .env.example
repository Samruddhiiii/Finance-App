# Database
# For local Postgres, replace USER/PASSWORD/DBNAME as needed.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DBNAME?schema=public"

# Optional for Prisma CLI operations (migrate/introspect) when using pooled connections.
# If you are using a direct connection as DATABASE_URL, you can keep this the same value.
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/DBNAME?schema=public"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."
CLERK_SECRET_KEY="sk_..."

# Gemini
GEMINI_API_KEY="..."

# Optional
ARCJET_KEY="..."
RESEND_API_KEY="..."
